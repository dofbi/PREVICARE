---
import Layout from '../../../layouts/Layout.astro';
import DashboardShell from '../../../components/DashboardShell.astro';
import { XalimaForm } from '../../../components/employee/XalimaForm.tsx';
import { createClient } from '../../../lib/supabase';

const { user } = Astro.locals;

if (!user) {
  return Astro.redirect('/connexion');
}

const supabase = createClient({ request: Astro.request, cookies: Astro.cookies });

const { data: profile } = await supabase
  .from('profiles')
  .select('first_name, last_name, organization')
  .eq('id', user.id)
  .single();

const { data: employeeDetails } = await supabase
  .from('employee_details')
  .select('current_position, employer_name, employer_hr_contact')
  .eq('id', user.id)
  .single();

const userProfile = {
  employee_name: [profile?.first_name, profile?.last_name].filter(Boolean).join(' ') || '',
  employee_position: employeeDetails?.current_position || '',
  company_name: profile?.organization || employeeDetails?.employer_name || '',
  recipient: employeeDetails?.employer_hr_contact || '',
};
---

<Layout title="Xalima — Rédaction de Courriers - PREVICARE EMPLOI">
  <DashboardShell title="Xalima — Assistant de Rédaction">

    <!-- Breadcrumbs -->
    <nav class="flex mb-6" aria-label="Breadcrumb">
      <ol class="flex items-center space-x-4">
        <li><a href="/espace-employes" class="text-gray-400 hover:text-gray-500">Tableau de bord</a></li>
        <li><span class="text-gray-300">/</span></li>
        <li><a href="/espace-employes/juridique" class="text-gray-400 hover:text-gray-500">Juridique</a></li>
        <li><span class="text-gray-300">/</span></li>
        <li><span class="text-gray-500">Courriers</span></li>
      </ol>
    </nav>

    <!-- En-tête Xalima -->
    <div class="mb-8 rounded-xl p-6 shadow-lg" style="background: linear-gradient(135deg, #92400e 0%, #d97706 100%);">
      <div class="flex flex-col md:flex-row md:items-center gap-4">
        <div class="flex items-center gap-4">
          <div class="flex-shrink-0 w-16 h-16 bg-white/20 rounded-2xl flex items-center justify-center">
            <svg class="w-9 h-9 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
            </svg>
          </div>
          <div>
            <h1 class="text-2xl font-bold text-white">Xalima</h1>
            <p class="text-white/80 text-sm">Votre assistant IA de rédaction de courriers professionnels</p>
          </div>
        </div>
        <div class="md:ml-auto flex flex-wrap gap-3">
          <a href="/espace-employes/juridique/setlou" class="flex items-center gap-2 bg-white/10 hover:bg-white/20 text-white rounded-lg px-3 py-2 text-xs font-medium transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
            Consulter SETLOU pour des conseils juridiques
          </a>
        </div>
      </div>
      <div class="mt-4 grid grid-cols-1 md:grid-cols-3 gap-3">
        <div class="bg-white/10 rounded-lg p-3">
          <p class="text-white/60 text-xs mb-1">Spécialité</p>
          <p class="text-white text-sm font-medium">Rédaction guidée de courriers</p>
        </div>
        <div class="bg-white/10 rounded-lg p-3">
          <p class="text-white/60 text-xs mb-1">Base légale</p>
          <p class="text-white text-sm font-medium">Droit du travail sénégalais</p>
        </div>
        <div class="bg-white/10 rounded-lg p-3">
          <p class="text-white/60 text-xs mb-1">Types disponibles</p>
          <p class="text-white text-sm font-medium">10 types de courriers</p>
        </div>
      </div>
    </div>

    <!-- Distinction des rôles -->
    <div class="grid gap-4 mb-8 md:grid-cols-3">
      <div class="bg-amber-50 border border-amber-200 rounded-xl p-4">
        <div class="flex items-center gap-3 mb-2">
          <div class="w-8 h-8 bg-amber-100 rounded-lg flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
            </svg>
          </div>
          <p class="font-semibold text-amber-900 text-sm">Xalima — ici</p>
        </div>
        <p class="text-amber-700 text-xs">Génération guidée de courriers professionnels (formulaire → courrier complet)</p>
      </div>

      <div class="bg-blue-50 border border-blue-200 rounded-xl p-4">
        <div class="flex items-center gap-3 mb-2">
          <div class="w-8 h-8 bg-blue-100 rounded-lg flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <p class="font-semibold text-blue-900 text-sm">SETLOU — Assistance</p>
        </div>
        <p class="text-blue-700 text-xs">Conseils juridiques, droits des employés, procédures RH</p>
        <a href="/espace-employes/juridique/setlou" class="text-blue-600 hover:text-blue-700 text-xs font-medium mt-2 block">Consulter SETLOU →</a>
      </div>

      <div class="bg-gray-50 border border-gray-200 rounded-xl p-4">
        <div class="flex items-center gap-3 mb-2">
          <div class="w-8 h-8 bg-gray-100 rounded-lg flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />
            </svg>
          </div>
          <p class="font-semibold text-gray-900 text-sm">Assistant PREVICARE</p>
        </div>
        <p class="text-gray-600 text-xs">Guide de navigation de l'application (bulle flottante en bas à droite)</p>
      </div>
    </div>

    <!-- Interface Xalima -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100">
      <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between">
        <div>
          <h3 class="text-lg font-semibold text-gray-900">✍️ Rédigez votre courrier</h3>
          <p class="text-sm text-gray-500 mt-0.5">Sélectionnez un type, remplissez le formulaire et laissez Xalima rédiger pour vous</p>
        </div>
      </div>
      <div class="p-6">
        <XalimaForm userProfile={userProfile} client:load />
      </div>
    </div>

  </DashboardShell>
</Layout>
